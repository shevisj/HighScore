HIGHSCORE_PORT=8081
HIGHSCORE_DB_URL=mongodb://localhost:27017/highscore

HIGHSCORE_SESSION_SECRET=yoursupersecret

# Set to require a secret on all write routes (POST/PUT/DELETE /api/scores).
# Leave empty to keep writes open.
HIGHSCORE_WRITE_PASSWORD=
# When true, write routes expect a per-request HMAC token in the
# `x-highscore-token` header instead of the raw password. The token binds
# the request to its payload, so it cannot be reused to write different data.
HIGHSCORE_WRITE_TOKEN=false
# When true, posting a score whose name + value + category already exist
# returns the existing score instead of inserting a duplicate (idempotent
# POST, e.g. for client retries). Session is ignored in the match.
HIGHSCORE_DEDUPE_SCORES=false

HIGHSCORE_TITLE=HighScore
HIGHSCORE_DESCRIPTION=Open Source leaderboard
HIGHSCORE_LOGO_URL=/logo.png
HIGHSCORE_FAVICON_URL=/favicon.ico
HIGHSCORE_CSS_URL=

HIGHSCORE_DOWNLOAD_URL=
HIGHSCORE_WINDOWS_DOWNLOAD_URL=
HIGHSCORE_LINUX_DOWNLOAD_URL=
HIGHSCORE_MACOS_DOWNLOAD_URL=
HIGHSCORE_ANDROID_DOWNLOAD_URL=
HIGHSCORE_IOS_DOWNLOAD_URL=

HIGHSCORE_USERNAME_DOCS=
HIGHSCORE_PASSWORD_DOCS=

HIGHSCORE_USERNAME_METRICS=
HIGHSCORE_PASSWORD_METRICS=

HIGHSCORE_RATE_LIMIT_MINUTE=
HIGHSCORE_RATE_LIMIT_NUMBER=

HIGHSCORE_PRIVACY_EMAIL=
HIGHSCORE_PRIVACY_WEBSITE=
HIGHSCORE_PRIVACY_COUNTRY=

HIGHSCORE_DISABLE_DOCS=false
HIGHSCORE_DISABLE_METRICS=false
HIGHSCORE_DISABLE_BAD_WORDS=false
HIGHSCORE_DISABLE_RATE_LIMIT=false