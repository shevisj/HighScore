    "globals": "^15.0.0",
    "jest": "^30.4.2",
    "prettier": "^3.8.4",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "tsconfig-paths": "^4.2.0",
    "tslib": "^2.8.1",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.62.0",
    "vitepress": "^1.6.4",
    "vue": "^3.5.38"
  },
  "tsed": {
    "packageManager": "npm",
    "convention": "default",
    "architecture": "default"
  },
  "overrides": {
    "mongodb-memory-server": "^10.1.4",
    "mongodb-memory-server-core": "^10.1.4"
  }
