{
  "name": "high-score",
  "version": "0.4.2",
  "description": "",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "npm run barrels && tsc --project tsconfig.compile.json",
    "barrels": "barrelsby --config .barrelsby.json -q",
    "start": "npm run barrels && tsnd --inspect --ignore-watch node_modules --respawn --transpile-only -r tsconfig-paths/register src/index.ts",
    "start:prod": "cross-env NODE_ENV=production node dist/src/index.js",
    "test:unit": "cross-env NODE_ENV=test MONGOMS_VERSION=7.0.14 MONGOMS_DISTRO=ubuntu-22.04 jest --forceExit --detectOpenHandles",
    "test:lint": "eslint .",
    "test:lint:fix": "eslint . --fix",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:serve": "vitepress serve docs",
    "release": "node ./scripts/version"
  },
  "dependencies": {
    "@tsed/ajv": "^7.87.9",
    "@tsed/common": "^7.87.9",
    "@tsed/core": "^7.87.9",
    "@tsed/di": "^7.87.9",
    "@tsed/engines": "^7.87.9",
    "@tsed/exceptions": "^7.87.9",
    "@tsed/json-mapper": "^7.87.9",
    "@tsed/logger": "^6.7.8",
    "@tsed/logger-file": "^6.7.8",
    "@tsed/mongoose": "^7.87.9",
    "@tsed/platform-cache": "^7.87.9",
    "@tsed/platform-exceptions": "^7.87.9",
    "@tsed/platform-express": "^7.87.9",
    "@tsed/platform-log-middleware": "^7.87.9",
    "@tsed/platform-middlewares": "^7.87.9",
    "@tsed/platform-params": "^7.87.9",
    "@tsed/platform-response-filter": "^7.87.9",
    "@tsed/platform-views": "^7.87.9",
    "@tsed/schema": "^7.87.9",
    "@tsed/swagger": "^7.87.9",
    "ajv": "^8.20.0",
    "bad-words": "^3.0.4",
    "barrelsby": "^2.8.1",
    "body-parser": "^1.20.3",
    "compression": "^1.8.1",
    "connect-mongo": "^6.0.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "cross-env": "^7.0.3",
    "dayjs": "^1.11.21",
    "dotenv": "^17.4.2",
    "dotenv-expand": "^13.0.0",
    "dotenv-flow": "^4.1.0",
    "express": "^4.21.2",
    "express-basic-auth": "^1.2.1",
    "express-rate-limit": "^8.5.2",
    "express-session": "^1.18.1",
    "express-useragent": "^1.0.15",
    "method-override": "^3.0.0",
    "mongoose": "^8.0.0",
    "multer": "^1.4.5-lts.1",
    "prom-client": "^15.1.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@geut/chan": "^3.2.9",
    "@tsed/components-scan": "^7.87.9",
    "@tsed/testing-mongoose": "^7.87.9",
    "@types/bad-words": "^3.0.3",
    "@types/compression": "^1.8.1",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/express-session": "^1.18.1",
    "@types/express-useragent": "^1.0.5",
    "@types/jest": "^30.0.0",
